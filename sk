#!/usr/bin/env bash
set -euo pipefail
IFS=$'\n\t'

APP_NAME="sk"
SERVICE_PREFIX="${SK_SERVICE_PREFIX:-sk:}"
VERSION="0.1.0"

print_help() {
  cat <<'EOF'
sk - macOS Keychain helper for storing secrets by key

Made by Diego Marinho de Oliveira

Usage:
  sk add -k KEY -v VALUE [-u USER]
  sk get -k KEY [-u USER]
  sk list [-u USER] [--keys]
  sk remove -k KEY [-u USER] [-y]
  sk install
  sk uninstall
  sk version
  sk -h | --help
  sk -V | --version

Commands:
  add       Store a secret in macOS Keychain
  get       Read a secret from macOS Keychain
  list      List sk entries (masked)
  remove    Delete a secret from macOS Keychain
  install   Install sk to ~/.local/bin/sk
  uninstall Remove sk from ~/.local/bin/sk

Options:
  -k, --key     Key name (required for add/get/remove)
  -v, --value   Secret value (required for add)
  --stdin       Read secret value from stdin (add command)
  -u, --user    Account name (default: $USER)
  -y, --yes     Skip confirmation for remove
  -h, --help    Show this help
  -V, --version Show version
  --keys        List keys only (list command)

Environment:
  SK_INSTALL_DIR  Override install directory (default: ~/.local/bin)
  SK_SERVICE_PREFIX  Override service prefix (default: sk:)

Examples:
  sk add -k OPENAI_API_KEY -v "sk-xxxx"
  printf '%s' "sk-xxxx" | sk add -k OPENAI_API_KEY --stdin
  printf '%s' "sk-xxxx" | sk add -k OPENAI_API_KEY -v -
  export OPENAI_API_KEY=$(sk get -k OPENAI_API_KEY)
  sk list
  sk list --keys
  sk remove -k OPENAI_API_KEY
EOF
}

error() {
  printf 'Error: %s\n' "$1" >&2
}

ensure_darwin() {
  if [[ "$(uname -s)" != "Darwin" ]]; then
    error "sk is supported on macOS only"
    exit 1
  fi
}

print_version() {
  printf '%s %s\n' "$APP_NAME" "$VERSION"
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || { error "Missing dependency: $1"; exit 1; }
}

require_value() {
  local opt="$1" val="${2:-}"
  if [[ -z "$val" ]]; then
    error "Missing value for $opt"
    exit 1
  fi
  printf '%s' "$val"
}

validate_key() {
  local key="$1"
  if [[ -z "$key" ]]; then
    error "Key cannot be empty"
    exit 1
  fi
  if [[ "$key" =~ [[:space:]] ]]; then
    error "Key cannot contain whitespace"
    exit 1
  fi
}

script_path() {
  local dir
  dir="$(cd "$(dirname "$0")" && pwd)"
  printf '%s/%s\n' "$dir" "$(basename "$0")"
}

mask_value() {
  local value="$1"
  if [[ -z "$value" ]]; then
    printf '****\n'
    return
  fi
  if [[ ${#value} -le 4 ]]; then
    printf '%s****\n' "$value"
    return
  fi
  printf '%s****\n' "${value:0:4}"
}

parse_add() {
  local key="" value="" user="${USER}" read_stdin="false"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -k|--key) key="$(require_value "$1" "$2")"; shift 2 ;;
      -v|--value) value="$(require_value "$1" "$2")"; shift 2 ;;
      --stdin) read_stdin="true"; shift ;;
      -u|--user) user="$(require_value "$1" "$2")"; shift 2 ;;
      -h|--help) print_help; exit 0 ;;
      *) error "Unknown option: $1"; exit 1 ;;
    esac
  done
  if [[ -z "$key" ]]; then
    error "add requires -k KEY"
    exit 1
  fi
  validate_key "$key"
  if [[ -z "$value" && "$read_stdin" != "true" ]]; then
    error "add requires -v VALUE or --stdin"
    exit 1
  fi
  if [[ -n "$value" && "$read_stdin" == "true" ]]; then
    error "Use -v VALUE or --stdin, not both"
    exit 1
  fi
  if [[ "$read_stdin" == "true" ]]; then
    if ! IFS= read -r value; then
      error "No value provided on stdin"
      exit 1
    fi
  fi
  if [[ "$value" == "-" ]]; then
    if ! IFS= read -r value; then
      error "No value provided on stdin"
      exit 1
    fi
  fi
  require_cmd security
  security add-generic-password -a "$user" -s "${SERVICE_PREFIX}${key}" -w "$value" -U >/dev/null
  printf 'Stored key "%s" for user "%s"\n' "$key" "$user"
}

parse_get() {
  local key="" user="${USER}"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -k|--key) key="$(require_value "$1" "$2")"; shift 2 ;;
      -u|--user) user="$(require_value "$1" "$2")"; shift 2 ;;
      -h|--help) print_help; exit 0 ;;
      *) error "Unknown option: $1"; exit 1 ;;
    esac
  done
  if [[ -z "$key" ]]; then
    error "get requires -k KEY"
    exit 1
  fi
  validate_key "$key"
  require_cmd security
  local value
  if ! value=$(security find-generic-password -a "$user" -s "${SERVICE_PREFIX}${key}" -w 2>/dev/null); then
    error "Key not found: $key"
    exit 1
  fi
  printf '%s\n' "$value"
}

parse_list() {
  local user="${USER}" keys_only="false"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -u|--user) user="$(require_value "$1" "$2")"; shift 2 ;;
      --keys) keys_only="true"; shift ;;
      -h|--help) print_help; exit 0 ;;
      *) error "Unknown option: $1"; exit 1 ;;
    esac
  done
  require_cmd security
  require_cmd awk
  require_cmd sort
  local services printed
  printed=0
  services=$(security dump-keychain 2>/dev/null | awk -F'"' '/"svce"<blob>="/ {print $2}' | awk -v prefix="$SERVICE_PREFIX" 'index($0,prefix)==1' | sort -u || true)
  if [[ -z "$services" ]]; then
    printf 'No sk entries found.\n'
    return
  fi
  local svc key value masked
  while IFS= read -r svc; do
    key="${svc#${SERVICE_PREFIX}}"
    value=""
    if ! value=$(security find-generic-password -a "$user" -s "$svc" -w 2>/dev/null); then
      continue
    fi
    if [[ "$keys_only" == "true" ]]; then
      printf '%s\n' "$key"
    else
      masked=$(mask_value "$value")
      printf '%s\t%s\n' "$key" "$masked"
    fi
    printed=1
  done <<< "$services"
  if [[ "$printed" -eq 0 ]]; then
    printf 'No sk entries found for user "%s".\n' "$user"
  fi
}

parse_remove() {
  local key="" user="${USER}" yes="false"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -k|--key) key="$(require_value "$1" "$2")"; shift 2 ;;
      -u|--user) user="$(require_value "$1" "$2")"; shift 2 ;;
      -y|--yes) yes="true"; shift ;;
      -h|--help) print_help; exit 0 ;;
      *) error "Unknown option: $1"; exit 1 ;;
    esac
  done
  if [[ -z "$key" ]]; then
    error "remove requires -k KEY"
    exit 1
  fi
  validate_key "$key"
  require_cmd security
  if [[ "$yes" != "true" ]]; then
    read -r -p "Remove key '$key' for user '$user'? [y/N] " confirm
    case "$confirm" in
      y|Y) ;;
      *) printf 'Aborted.\n'; exit 1 ;;
    esac
  fi
  if ! security delete-generic-password -a "$user" -s "${SERVICE_PREFIX}${key}" >/dev/null; then
    error "Key not found: $key"
    exit 1
  fi
  printf 'Removed key "%s" for user "%s"\n' "$key" "$user"
}

parse_install() {
  local dest_dir dest src
  dest_dir="${SK_INSTALL_DIR:-$HOME/.local/bin}"
  dest="${dest_dir}/${APP_NAME}"
  src="$(script_path)"
  if [[ "$src" == "$dest" ]]; then
    printf '%s is already installed at %s\n' "$APP_NAME" "$dest"
    exit 0
  fi
  mkdir -p "$dest_dir"
  cp "$src" "$dest"
  chmod +x "$dest"
  case ":$PATH:" in
    *":$dest_dir:"*) printf 'Installed %s to %s\n' "$APP_NAME" "$dest" ;;
    *)
      printf 'Installed %s to %s\n' "$APP_NAME" "$dest"
      printf 'Add %s to your PATH: export PATH="%s:$PATH"\n' "$dest_dir" "$dest_dir"
      ;;
  esac
}

parse_uninstall() {
  local dest_dir dest
  dest_dir="${SK_INSTALL_DIR:-$HOME/.local/bin}"
  dest="${dest_dir}/${APP_NAME}"
  if [[ -f "$dest" ]]; then
    rm -f "$dest"
    printf 'Removed %s from %s\n' "$APP_NAME" "$dest"
  else
    printf 'No install found at %s\n' "$dest"
  fi
}

main() {
  local cmd="${1:-}"
  if [[ -z "$cmd" || "$cmd" == "-h" || "$cmd" == "--help" ]]; then
    print_help
    exit 0
  fi
  if [[ "$cmd" == "-V" || "$cmd" == "--version" ]]; then
    print_version
    exit 0
  fi
  ensure_darwin
  shift || true
  case "$cmd" in
    add) parse_add "$@" ;;
    get) parse_get "$@" ;;
    list) parse_list "$@" ;;
    remove|rm|delete) parse_remove "$@" ;;
    install) parse_install "$@" ;;
    uninstall) parse_uninstall "$@" ;;
    help) print_help; exit 0 ;;
    version) print_version; exit 0 ;;
    *) error "Unknown command: $cmd"; print_help; exit 1 ;;
  esac
}

main "$@"
